# --- SECURITY & CRYPTOGRAPHY ---
SECRET_KEY=forgetguard_secret_key_change_me_in_production_12345!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- PERSISTENCE ---
# Use SQLite locally out of the box, swap for Postgres in production
DATABASE_URL=sqlite:///forgetguard.db
# DATABASE_URL=postgresql://forgetguard:forgetguard_secure_password_99@localhost:5432/forgetguard

# --- JOBS QUEUE ---
REDIS_URL=redis://localhost:6379/0

# --- STORAGE ---
STORAGE_DIR=./data

# --- CODE EVALUATION SANDBOX ---
SANDBOX_TIMEOUT_SEC=5
SANDBOX_MAX_MEMORY_MB=256

# --- FRONTEND CLIENT ---
NEXT_PUBLIC_API_URL=http://localhost:8000
